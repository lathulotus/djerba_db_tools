{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "RUO.schema.json",
    "$comment": "Latest report from 13/01/2025",
    "title": "RUO - Report Structure Schema",
    "description": "Schema documentation of RUO report structures",
    "type": "object",

    "properties":{
        "results":{
            "description": "Results from testing; merged",
            "type": "object",
            "properties":{
                "assay": {
                    "description": "Type of assay used for sequencing (WGTS, WGS, TAR)",
                    "type": "string",
                    "enum": ["WGTS", "WGS", "TAR"]
                },
                "primary_cancer": {
                    "description": "Cancer type.",
                    "type": "string",
                    "enum": ["Pancreatic adenocarcinoma", "Hepatobiliary Tumour", "Multiple Myeloma", "Breast Cancer", "Invasive breast carcinoma"]
                },
                "site_of_biopsy":{
                    "description": "Biopsy type/location (cfDNA)",
                    "type": "string"
                },
                "study":{
                    "description": "Research study",
                    "type": "string"
                },


                "known_variants":{
                    "description": "Previously known variants (<em>GENE</em> c.notation (p.notation)",
                    "type": "string"
                },
                "cancer_content":{
                    "description": "Amount of cancer cells",
                    "type": "integer"
                },
                "raw_coverage":{
                    "description": "Sequences read coverage",
                    "type": "integer"
                },
                "unique_coverage":{
                    "description": "Unique read coverage",
                    "type": "integer"
                },


                "Clinically relevant variants":{
                    "description": "Number of clinically relevant variants",
                    "type": "integer"
                },
                "Total variants":{
                    "description": "Number of total variants identified",
                    "type": "integer"
                },
                "Has expression data":{
                    "description": "Whether variant is expressed",
                    "type": "boolean"
                },
                 

                "somatic mutations":{
                    "description": "Number of somatic mutations identified",
                    "type": "integer"
                },
                "coding sequence mutations":{
                    "description": "Number of mutations in coding sequence",
                    "type": "integer"
                },
                "oncogenic mutations":{
                    "description": "Number of oncogenic mutations identified",
                    "type": "integer"
                },
                

                "Gene":{
                    "description": "Gene containing identified variant",
                    "type": "array",
                    "items":{
                        "type": "string"
                    }
                },
                "protein":{
                    "description": "Protein alteration",
                    "type": "array",
                    "items":{
                        "type": "string"
                    }
                },
                "type":{
                    "description": "Type of specific alteration or biological event (Missense Mutation, Nonsense Mutation, Frame Shift Del, Frame Shift Ins, Splice Site, Splice Region)",
                    "type": "string",
                    "enum": ["Missense Mutation", "Nonsense Mutation", "Frame Shift Del", "Frame Shift Ins", "Splice Site", "Splice Region"]
                },
                "vaf":{
                    "description": "Variant allele frequency",
                    "type": "array",
                    "items":{
                        "type": "integer"
                    }
                },
                "depth":{
                    "description": "Variant read depth",
                    "type": "array",
                    "items":{
                        "type": "string"
                    }
                },
                "LOH":{
                    "description": "Whether loss of heterozygosity is exhibited",
                    "type": "array",
                    "items":{
                        "type": "boolean"
                    }
                },
                "Chromosome":{
                    "decription": "Chromosomal position of variant (ie 17p13.1)",
                    "type": "array",
                    "items":{
                        "type": "string"
                    }
                }
            }
        }
    }
}