{
    "$id":"https://https://github.com/oicr-gsi/djerba/tree/main/src/lib/djerba/plugins/case_overview/schema_case_overview.json",
    "title": "Results Structure for case_overview Plugin",
    "description": "Schema documentation of results structure for case_overview plugin.",
    "type": "object",

    "properties":{
        "case_overview":{
            "description": "Plugin for Case Overview report section",
            "type": "object",
            "properties":{

                "plugin_name":{
                    "description": "case_overview plugin",
                    "type": "string"
                },

                "version":{
                    "description": "Plugin version (1.0.0)",
                    "type": "string"
                },

                "results":{
                    "description": "Results from case_overview plugin",
                    "type": "object",
                    "properties":{

                        "assay": {
                            "description": "Type of assay used for sequencing. Short name typically used.",
                            "type": "string",
                            "enum": ["WGTS", "WGS", "WES", "WTS", "pWGS", "sWGS", "TAR"]
                        },

                        "assay_description": {
                            "description": "Description of assay",
                            "type": "string",
                            "enum": ["Whole genome and transcriptome sequencing (WGTS)-80X Tumour, 30X Normal (v6.0)"]
                        },

                        "primary_cancer": {
                            "description": "Cancer type.",
                            "type": "string"
                        },
                        
                        "site_of_biopsy":{
                            "description": "Biopsy type/location",
                            "type": "string",
                            "enum": ["Adipose", "Adnexa", "Adrenal Gland", "Anus", "Anorectal", "Appendix", "Ascites Fluid", "Astrocytoma", "Ampulla of Vater", "Axillary", "Back", "Bile Duct", "Biliary", "Bladder", "Bone Marrow", "Brain", "Bone", "Breast", "Buccal Cells", "Bowel", "Carotid Artery", "Cord Blood", "Cecum", "Cervix", "cfDNA", "Chest Wall", "Conjunctiva", "Cheek", "Central Nervous System", "Colon", "Colorectal", "Cul-de-sac", "Circulating Tumour Cells", "Diaphragm", "Duodenum", "Ear", "Endometrial", "Epidural mass", "Esophagus", "Eye", "Fallopian Tube", "Fibroid", "Fimbriae", "Fundus", "Foreskin", "Foot", "Gastric Margin", "Gallbladder", "Gastroesophageal Junction", "Gastrointestinal stromal", "Gastrojejunal", "Glomus", "Gingiva", "Groin", "Genital Tract", "Hypopharynx", "Heart", "ileocecum", "Ileum", "Iliac Crest", "Kidney", "Lacrimal Sac", "Limb", "Leukocyte", "Leg", "Large Intestine", "Lymph Node", "Lymphoblast", "Lip", "Placenta", "Lung", "Liver", "Larynx", "Lymphocyte", "Mediastinum", "Mesenchyme", "Mandible", "Mouth", "Mesentary", "Muscle", "Maxilla", "Neck", "Unknown", "Nose", "Nasopharynx", "Oral Cavity", "Omentum", "Orbit", "Ovary", "Pancreas", "Peripheral Blood", "Pancreatobiliary", "Parathyroid", "Pelvic", "Parotid gland", "Paratracheal", "Penis", "Plasma", "Perihepatic", "Peritoneum", "Peripheral Nerve", "Peri-aorta", "Prostate", "Platelet", "Palate", "Pleura", "Portocaval Space", "Pharynx", "periampullary", "Right Adnexa", "Rectosigmoid", "Rectum", "Rib", "Retroperitoneum", "Saliva", "Small Bowel", "Scalp", "Sigmoid Mass", "Serum", "Salivary Gland", "Small Intestine", "Skin", "Skull", "Skeletal Muscle", "Spine", "Soft Tissue", "Spleen", "Serosa", "Sinus", "Stomach", "Sternum", "Subcutaneous Tissue", "Testes", "Thymic Gland", "Thymus", "Tonsil", "Throat", "Trachea", "Tongue", "Thorax", "Thyroid", "Urachus", "Ureter", "Umbilical Cord", "Urine Pellet", "Urethra", "Urine Supernatant", "Uterus", "Urine", "Vagina", "Vulva"]
                        },

                        "donor":{
                            "description": "Donor ID",
                            "type": "string"
                        },

                        "study":{
                            "description": "Research study",
                            "type": "string"
                        },

                        "patient_study_id":{
                            "description": "Patient study ID",
                            "type": "string"
                        },

                        "tumour_id":{
                            "description": "Tumour ID",
                            "type": "string"
                        },

                        "normal_id":{
                            "description": "Normal ID",
                            "type": "string"
                        },

                        "report_id":{
                            "description": "Report ID",
                            "type": "string"
                        },

                        "requisition_approved":{
                            "definition": "Date of requisition approval (YYYY-MM-DD)",
                            "type": "string"
                        }
                    }
                }
            }
        }
    }
}