{
    "$id": "https://github.com/lathulotus/cgi_djerba/blob/main/1_djerbaSchemas/schema_master.json",
    "type": "object",
    "properties": {
        "core": {
            "type": "object",
            "properties": {
            "author": {"type": "string"},
            "document_config": {"type": "string"},
            "report_id": {"type": "string"},
            "core_version": {"type": "string"},
            "extract_time": {"type": "string"}
      }
    },

    "plugins": {
        "type": "object",
        "properties": {

            "genomic_landscape": {
                "type": "object",
                "properties": {
                    "plugin_name": {"type": "string"},
                     "version": {"type": "string"},
                     "priorities": {
                        "type": "object",
                        "properties": {
                            "configure": {"type": "integer"},
                            "extract": {"type": "integer"},
                            "render": {"type": "integer"}
                        }
                    },
                    "attributes": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": ["clinical", "supplementary", "failed", "research"]
                        }
                    },
                    "merge_inputs": {"type": "object"},
                    "results": {"type": "object"},
                    "url": {"type": "string"}
                },
                "required": ["plugin_name", "version", "priorities", "attributes", "merge_inputs", "results"]
            },
            
            "fusion":{
                "type": "object",
                "properties": {
                    "plugin_name": {"type": "string"},
                    "version": {"type": "string"},
                    "priorities": {
                        "type": "object",
                        "properties": {
                            "configure": {"type": "integer"},
                            "extract": {"type": "integer"},
                            "render": {"type": "integer"}
                        }
                    },
                    "attributes": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": ["clinical", "supplementary", "failed", "research"]
                        }
                    },
                    "merge_inputs": {"type": "object"},
                    "results": {"type": "object"},
                    "url": {"type": "string"}
                },
                "required": ["plugin_name", "version", "priorities", "attributes", "merge_inputs", "results"]
            }
        },

        "patternProperties": {
            "^[A-Za-z_.-]+$": {
                "type": "object",
                "properties": {
                    "plugin_name": {"type": "string"},
                    "priorities": {
                        "type": "object",
                        "properties": {
                            "configure": {"type": "integer"},
                            "extract": {"type": "integer"},
                            "render": {"type": "integer"}
                        }
                    },
                    "attributes": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "enum": ["clinical", "supplementary", "failed", "research"]
                        }
                    },
                    "merge_inputs": {"type": "object"},
                    "results": {"type": "object"},
                    "url": {"type": "string"},
                    "version": {"type": "string"}
                },
                "required": ["plugin_name", "priorities", "attributes", "merge_inputs", "results", "version"]
            }
        },
        "required": ["genomic_landscape", "fusion"]
    },

    "supplement.body": {
        "type": "object",
        "properties": {
            "plugin_name": {"type": "string"},
            "priorities": {
                "type": "object",
                "properties": {
                    "configure": {"type": "integer"},
                    "extract": {"type": "integer"},
                    "render": {"type": "integer"}
                }
            },
            "attributes": {
                "type": "array",
                "items": {
                    "type": "string",
                    "enum": ["clinical", "supplementary", "failed", "research"]
                }
            },
            "merge_inputs": {"type": "object"},
            "results": {
                "type": "object",
                "properties": {
                    "assay": {"type": "string"},
                    "components": {"type": "object"},
                    "failed": {"type": "boolean"},
                    "author": {"type": "string"},
                    "extract_date": {"type": "string"},
                    "include_signoffs": {"type": "boolean"},
                    "template_dir": {"type": "string"},
                    "report_signoff_date": {"type": "string"},
                    "clinical_geneticist_name": {"type": "string"},
                    "clinical_geneticist_licence": {"type": "string"}
                }
            },
            "url": {"type": "string"},
            "version": {"type": "string"}
        },
        "required": ["plugin_name", "priorities", "attributes", "merge_inputs", "results", "version"]
    }
  }
}
